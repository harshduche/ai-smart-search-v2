# Qdrant Configuration
# Option 1: Local / self-hosted Qdrant (host + port)
QDRANT_HOST=localhost
QDRANT_PORT=6333
# Option 2: Qdrant Cloud (url + api_key) — takes priority over host/port when set
QDRANT_URL=
QDRANT_API_KEY=
# QDRANT_COLLECTION=security_footage

# Model Configuration
MODEL_NAME=Qwen/Qwen3-VL-Embedding-2B
RERANKER_MODEL_NAME=Qwen/Qwen3-VL-Reranker-2B
DEVICE=cuda
BATCH_SIZE=4
USE_RERANKER=false
PRELOAD_MODELS=true  # Set to false for faster restarts during development

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Data Paths
DATA_DIR=./data
RAW_DATA_DIR=./data/raw
FRAMES_DIR=./data/frames
THUMBNAILS_DIR=./data/thumbnails

# Frame Extraction
FRAME_RATE=1.0
THUMBNAIL_SIZE=224
SAVE_FULL_FRAMES=false
SAVE_THUMBNAILS=false

# Remote Embedding (scaled deployments with separate model server)
USE_REMOTE_EMBEDDINGS=false
MODEL_SERVER_URL=http://localhost:8001
MODEL_SERVER_TIMEOUT=300

# HuggingFace Cache (use local directory to avoid permission issues)
HF_HOME=./models/hf_cache
HF_HUB_CACHE=./models/hf_cache

# RabbitMQ Configuration
RABBITMQ_HOST=
RABBITMQ_PORT=
RABBITMQ_USER=
RABBITMQ_PASSWORD=
RABBITMQ_QUEUE=
RABBITMQ_PREFETCH_COUNT=

# AWS / S3 Configuration
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=
S3_ENDPOINT_URL=          # Optional: custom endpoint for MinIO / S3-compatible storage
S3_PRESIGNED_URL_EXPIRATION=3600   # Presigned URL lifetime in seconds (default 1 hour)
# Presigned URL format:
#   S3_SIGNATURE_VERSION=s3    → SigV2 (AWSAccessKeyId/Signature/Expires params) [default]
#   S3_SIGNATURE_VERSION=s3v4  → SigV4 (X-Amz-* params)
S3_SIGNATURE_VERSION=s3v4
#   S3_ADDRESSING_STYLE=path    → https://s3.<region>.amazonaws.com/<bucket>/<key> [default]
#   S3_ADDRESSING_STYLE=virtual → https://<bucket>.s3.<region>.amazonaws.com/<key>
S3_ADDRESSING_STYLE=path
# S3 Transfer Acceleration for faster downloads (requires acceleration enabled on bucket)
S3_USE_ACCELERATE=false

# MongoDB (for geospatial queries)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=video_rag

# Langfuse Configuration
LANGFUSE_ENABLED=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=


# Long Video Optimization (for 3+ hour drone footage)
# Videos longer than this threshold will use optimized settings
LONG_VIDEO_THRESHOLD_SECONDS=3600  # 1 hour (3600s)

# Reduced frame rate for long videos (e.g., 0.5 fps = 1 frame every 2 seconds)
# For a 3-hour video: 0.5 fps = 5,400 frames vs 1.0 fps = 10,800 frames
LONG_VIDEO_FRAME_RATE=0.5

# Semantic clip settings for temporal context
SEMANTIC_CLIP_DURATION=4.0  # Duration of each clip in seconds
SEMANTIC_CLIP_MAX_FRAMES=32  # Max frames per clip (prevents OOM)

# Reranker batch processing (higher = faster but more memory)
RERANKER_BATCH_SIZE=8  # Process 8 query-document pairs at once

